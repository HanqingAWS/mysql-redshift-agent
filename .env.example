AWS_REGION=us-west-2
# Bedrock inference-profile ID — 推荐 global. 跨区；us./jp./eu. 也可
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6
# pgvector 知识库的 embedding 模型（1024 维，中英混排）
EMBEDDING_MODEL_ID=cohere.embed-multilingual-v3

# ========== Redshift Serverless ==========
REDSHIFT_HOST=<your-workgroup>.<account-id>.<region>.redshift-serverless.amazonaws.com
REDSHIFT_PORT=5439
REDSHIFT_DB=dev
REDSHIFT_USER=admin
REDSHIFT_PASSWORD=<YOUR_REDSHIFT_PASSWORD>

# Proxy 的 pgx 驱动用 DSN 连 Redshift
REDSHIFT_DSN=postgres://admin:<YOUR_REDSHIFT_PASSWORD>@<your-workgroup>.<account-id>.<region>.redshift-serverless.amazonaws.com:5439/dev?sslmode=require

# ========== Aurora MySQL（业务源 + webui 直连 + agent 双边对比用） ==========
AURORA_HOST=<your-cluster>.cluster-xxxxx.<region>.rds.amazonaws.com
AURORA_PORT=3306
AURORA_USER=admin
AURORA_PASSWORD=<YOUR_AURORA_PASSWORD>
AURORA_DB=<your-db>

# ========== Proxy 白名单路由（可选） ==========
# MYSQL_DSN 空 → 所有 SQL 走 Redshift；设置后：命中 TABLE_WHITELIST 的表走 Redshift，其余直连 MySQL
MYSQL_DSN="admin:<YOUR_AURORA_PASSWORD>@tcp(<your-cluster>.cluster-xxxxx.<region>.rds.amazonaws.com:3306)/<your-db>?parseTime=true"
TABLE_WHITELIST=

# ========== Aurora PostgreSQL Serverless v2（pgvector 知识库） ==========
AURORA_PG_HOST=<your-pg-cluster>.cluster-xxxxx.<region>.rds.amazonaws.com
AURORA_PG_PORT=5432
AURORA_PG_DB=knowledge
AURORA_PG_USER=dbadmin
AURORA_PG_PASSWORD=<YOUR_PG_PASSWORD>
KNOWLEDGE_TOP_K=3
KNOWLEDGE_THRESHOLD=0.85
# 写入时向量去重阈值：>= 此值视为重复（只 bump hit_count）。实测数据：同模板
# 不同字面值 0.93–0.95；业务语义变化 (ORDER BY / NOT IN) 0.91–0.94；不同聚合 0.60。
# 0.94 是"压重复 + 留变化"的拐点。
KNOWLEDGE_DEDUP_THRESHOLD=0.94

# ========== Proxy 对外暴露的 MySQL 账号 ==========
# 客户端用这个账号连 proxy；Proxy 后端用自己的 DSN 连 Redshift
PROXY_MYSQL_USER=demo
PROXY_MYSQL_PASSWORD=<PICK_A_PASSWORD>
PROXY_MYSQL_DB=<your-db>

# ========== 月度 Snapshot → Parquet 导出（infra/06_planb_export.sh 用） ==========
AURORA_CLUSTER=<your-cluster>
S3_BUCKET=<your-bucket>-<account-id>-<region>

# ========== AWS 凭证 ==========
# 在 EC2 上跑时，如果 instance profile 已有权限可以全部留空（boto3/SDK 自动解析 IMDS）
# 本地跑时填你自己的 access key
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
